{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}, cinematic lighting, photorealistic, 4k, smooth camera movement, professional video production",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "{{seed}}",
      "steps": 30,
      "cfg": 7.5,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SVDLoader",
    "inputs": {
      "model_name": "svd_xt_1_1.safetensors",
      "num_frames": "{{num_frames}}",
      "fps": 24,
      "motion_bucket_id": 127,
      "augmentation_level": 0.0
    }
  },
  "8": {
    "class_type": "VideoLinearCFGGuidance",
    "inputs": {
      "model": ["7", 0],
      "min_cfg": 1.0
    }
  },
  "9": {
    "class_type": "SVDSampler",
    "inputs": {
      "model": ["8", 0],
      "init_image": ["6", 0],
      "num_frames": "{{num_frames}}",
      "seed": "{{seed}}",
      "steps": 25,
      "cfg": 2.5,
      "fps": 24,
      "motion_bucket_id": 127,
      "augmentation_level": 0.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "duration_sec": "{{duration_sec}}"
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["7", 2]
    }
  },
  "11": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "realistic_video",
      "fps": 24,
      "quality": 90
    }
  }
}
