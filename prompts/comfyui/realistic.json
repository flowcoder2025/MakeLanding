{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "realisticVision_v51.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt}}, cinematic lighting, photorealistic, 8k, high detail",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": "{{frame_count}}"
    }
  },
  "5": {
    "class_type": "ADE_AnimateDiffLoaderWithContext",
    "inputs": {
      "model_name": "animatediff_v2.ckpt",
      "model": ["1", 0],
      "context_options": ["6", 0]
    }
  },
  "6": {
    "class_type": "ADE_StandardUniformContextOptions",
    "inputs": {
      "context_length": 16,
      "context_stride": 1,
      "context_overlap": 4,
      "closed_loop": true
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["5", 0],
      "seed": "{{seed}}",
      "steps": 25,
      "cfg": 7.5,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "denoise": 1.0
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["1", 2]
    }
  },
  "9": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["8", 0],
      "frame_rate": "{{fps}}",
      "loop_count": 0,
      "filename_prefix": "makelanding_realistic",
      "format": "video/h264-mp4",
      "pingpong": false
    }
  }
}
