{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}, 3d character animation, stylized, Pixar style, dynamic motion, expressive character, vibrant colors",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "{{seed}}",
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "AnimateDiffLoader",
    "inputs": {
      "model_name": "animatediff_v3.safetensors",
      "num_frames": "{{num_frames}}",
      "fps": 24,
      "beta_schedule": "sqrt_linear"
    }
  },
  "8": {
    "class_type": "AnimateDiffSampler",
    "inputs": {
      "model": ["7", 0],
      "init_image": ["6", 0],
      "num_frames": "{{num_frames}}",
      "seed": "{{seed}}",
      "steps": 20,
      "cfg": 2.0,
      "fps": 24,
      "denoise": 0.9,
      "sampler_name": "euler",
      "scheduler": "normal",
      "duration_sec": "{{duration_sec}}"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["7", 2]
    }
  },
  "10": {
    "class_type": "FrameInterpolation",
    "inputs": {
      "images": ["9", 0],
      "multiplier": 2,
      "model_name": "rife_v4.6.safetensors"
    }
  },
  "11": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["10", 0],
      "filename_prefix": "3d_character_video",
      "fps": 24,
      "quality": 90
    }
  }
}
