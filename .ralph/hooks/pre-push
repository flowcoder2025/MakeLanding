#!/usr/bin/env bash
# pre-push hook: main 직접 push 방지
# 초기 셋업(WI-chore), PRD(WI-docs), fix_plan 커밋은 예외

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$current_branch" = "main" ]; then
  # 마지막 커밋 메시지 확인 — 시스템 커밋은 허용
  last_msg=$(git log -1 --format='%s')
  if echo "$last_msg" | grep -qP '^WI-(chore|docs)\s'; then
    exit 0
  fi

  echo ""
  echo "ERROR: main 브랜치에 직접 push할 수 없습니다."
  echo ""
  echo "  feature 브랜치를 만들고 PR을 통해 머지하세요:"
  echo "    git checkout -b feature/WI-NNN-feat-작업명"
  echo "    git push -u origin feature/WI-NNN-feat-작업명"
  echo "    gh pr create"
  echo ""
  exit 1
fi
